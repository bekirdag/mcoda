{
  "name": "mcoda",
  "version": "0.1.57",
  "description": "Local-first CLI for planning, documentation, and execution workflows with agent assistance.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bekirdag/mcoda.git"
  },
  "bugs": {
    "url": "https://github.com/bekirdag/mcoda/issues"
  },
  "homepage": "https://github.com/bekirdag/mcoda#readme",
  "license": "MIT",
  "author": "bekir dag",
  "keywords": [
    "mcoda",
    "cli",
    "planning",
    "backlog",
    "agent",
    "documentation",
    "openapi",
    "pdr",
    "sds"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:all": "pnpm run install:local:bins",
    "install:local": "node scripts/install-local-packages.js",
    "install:local:bins": "node scripts/install-local-packages.js --bins-only",
    "lint": "pnpm -r run lint",
    "release:publish:npm": "node scripts/publish-npm-packages.js",
    "release:publish:npm:dry-run": "node scripts/publish-npm-packages.js --dry-run",
    "test": "node tests/all.js",
    "test:repo": "node --input-type=module -e \"process.env.MCODA_SKIP_WORKSPACE_TESTS='1'; import('./tests/all.js');\"",
    "test:workspaces": "pnpm -r run test"
  },
  "pnpm": {
    "overrides": {
      "tar": "7.5.11",
      "flatted": "3.4.2",
      "minimatch": "10.2.3",
      "anymatch>picomatch": "2.3.2",
      "micromatch>picomatch": "2.3.2",
      "jest-util>picomatch": "4.0.4",
      "axios": "1.13.5",
      "systeminformation": "5.31.0",
      "serialize-javascript": "7.0.3"
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.3",
    "chai": "^6.2.2",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "mocha": "^11.7.5",
    "nock": "^14.0.10",
    "prettier": "^3.2.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
